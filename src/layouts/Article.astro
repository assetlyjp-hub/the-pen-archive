---
// Article.astro - 記事ページ用レイアウト
// Base.astroを継承して、記事固有のスタイルとメタを追加

import Base from './Base.astro';

// 記事プロパティの型定義
interface Props {
  title: string;
  description: string;
  category: string;
  publishedAt: string;
  updatedAt?: string;
  tags?: string[];
}

const { title, description, category, publishedAt, updatedAt, tags } = Astro.props;

// カテゴリの英語表示名マッピング
const categoryLabels: Record<string, string> = {
  review: 'Pen Review',
  ink: 'Ink Guide',
  nib: 'Nib Guide',
  comparison: 'Comparison',
  guide: 'Guide',
  beginner: 'Beginner',
};
---

<Base
  title={title}
  description={description}
  type="article"
>
  <!-- 記事一覧へ戻るリンク（上部） -->
  <div style="max-width: var(--container-narrow); margin: 0 auto; padding: calc(var(--space-2xl) + 60px) var(--space-md) 0;">
    <a href="/magazine/" class="article-back-link">&larr; Back to Magazine</a>
  </div>

  <!-- 記事ヘッダー -->
  <div class="page-header" style="padding-top: var(--space-md);">
    <p class="article-card__category">{categoryLabels[category] || category}</p>
    <h1 class="page-header__title">{title}</h1>
    <p class="page-header__description">
      Published: {publishedAt}
      {updatedAt && ` · Updated: ${updatedAt}`}
    </p>
  </div>

  <!-- 記事本文 -->
  <div class="article-layout">
    <slot />

    <!-- 記事一覧へ戻るリンク（下部） -->
    <nav style="margin-top: var(--space-xl); padding-top: var(--space-md); border-top: 1px solid var(--color-border);">
      <a href="/magazine/" class="article-back-link">&larr; Back to Magazine</a>
    </nav>
  </div>
</Base>
