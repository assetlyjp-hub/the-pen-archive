---
// privacy.astro - プライバシーポリシーページ
import Base from '../layouts/Base.astro';
---

<Base
  title="Privacy Policy"
  description="Privacy Policy for The Pen Archive"
>
  <div class="page-header">
    <h1 class="page-header__title">Privacy Policy</h1>
  </div>

  <div class="container container--narrow">
    <div class="article-layout">
      <p>Last updated: April 2026</p>

      <h2>Information We Collect</h2>
      <p>
        The Pen Archive does not collect personal information from visitors.
        We do not require user accounts, and we do not store cookies for tracking purposes.
      </p>

      <h2>Analytics</h2>
      <p>
        We may use privacy-friendly analytics tools to understand how visitors use our site.
        This data is aggregated and does not identify individual visitors.
      </p>

      <h2>Affiliate Links</h2>
      <p>
        Our site contains affiliate links to retailers such as Amazon. When you click these links,
        the retailer may use cookies to track the referral. Please refer to the respective
        retailer's privacy policy for details on their data practices.
      </p>

      <h2>Third-Party Services</h2>
      <p>
        We use Google Fonts to deliver web fonts. Google may collect anonymous usage data
        as described in their privacy policy.
      </p>

      <h2>Changes to This Policy</h2>
      <p>
        We may update this privacy policy from time to time. Any changes will be posted on this page.
      </p>

      <h2>Contact</h2>
      <p>
        If you have questions about this privacy policy, contact us at:
        <br />info@thepenarchive.com
      </p>
    </div>
  </div>
</Base>
