import Base from '../layouts/Base.astro';
---

<Base
  title="About"
  description="About The Pen Archive — the definitive database of fountain pens, inks, and writing instruments for enthusiasts worldwide."
>
  <div class="page-header">
    <h1 class="page-header__title">About</h1>
  </div>

  <div class="container container--narrow">
    <div class="article-layout">
      <h2>The Pen Archive</h2>
      <p>
        The Pen Archive is the definitive online database for fountain pens and fine writing instruments.
        We catalog and review pens from the world's finest makers — from the legendary Japanese trio of
        Pilot, Sailor, and Platinum to European icons like Pelikan, Montblanc, and LAMY.
      </p>
      <p>
        Our mission is to help writers, collectors, and enthusiasts worldwide find the
        perfect fountain pen for their needs. We provide detailed specifications, ink
        comparisons with radar charts, and honest reviews based on real-world usage.
      </p>

      <h2>What Makes Us Different</h2>
      <p>
        Unlike generic review sites, we specialize exclusively in fountain pens and inks. Our ink
        database with radar charts helps you understand exactly what each ink offers in terms of
        saturation, shading, sheen, and water resistance. Our comparison tool lets you put any two
        pens side by side. And our magazine articles go deep into the craft and science of writing instruments.
      </p>

      <h2>Affiliate Disclosure</h2>
      <p>
        The Pen Archive is a participant in affiliate programs including Amazon Associates.
        This means we may earn a small commission when you purchase through our links, at no
        additional cost to you. This helps us maintain and improve this resource.
      </p>
      <p>
        Our reviews and recommendations are independent. Affiliate relationships never influence
        our ratings or which pens we recommend.
      </p>

      <h2>Disclaimer</h2>
      <p>
        The information provided on The Pen Archive is for general informational purposes
        only. While we strive for accuracy, prices, availability, and specifications may change
        without notice. We are not responsible for any purchasing decisions made based on our content.
      </p>
      <p>
        Pen specifications (weight, nib sizes, etc.) are sourced from manufacturers
        and may vary slightly between individual units.
      </p>

      <h2>Contact</h2>
      <p>
        Have questions, corrections, or suggestions? We'd love to hear from you.
        <br />Email: info@thepenarchive.com
      </p>
    </div>
  </div>
</Base>
